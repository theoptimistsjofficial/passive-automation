GEMINI_API_KEY=

# Free at https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional — premium voice. Free tier at https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Channel branding
CHANNEL_NAME=OptimistMantra
DEFAULT_NICHE=positive_thinking
