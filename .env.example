# ============================================================
# PASSIVE AUTOMATION — .env template
#
# Copy this file to .env on your local machine and fill in the
# real values. NEVER commit the actual .env file — it's gitignored.
#
# Setup:
#   cp .env.example .env
#   # then edit .env with real keys
#
# On Legion:
#   git pull origin main
#   cp .env.example .env
#   # edit .env with your real values
#
# All keys are optional — pipeline falls back gracefully if any are missing.
# But quality drops noticeably without ElevenLabs (voice) or Fal.ai (video).
# ============================================================

# --- SCRIPT (Gemini 2.5 Flash — free tier, 1500 requests/day) ---
# Get at: https://aistudio.google.com/apikey
# Falls back to hardcoded template scripts if missing.
GEMINI_API_KEY=

# --- VOICE OPTION 1 (RECOMMENDED): Google Cloud Text-to-Speech Neural ---
# Free tier: 1M chars/month (WaveNet/Neural2 voices), near-ElevenLabs quality.
# Setup:
#   1. Go to console.cloud.google.com — use the same project as YouTube Data API
#   2. Enable "Cloud Text-to-Speech API"
#   3. Credentials → Create Credentials → API Key
#   4. (Optional) Restrict to Cloud Text-to-Speech API only
GOOGLE_TTS_API_KEY=

# Voice options (see https://cloud.google.com/text-to-speech/docs/voices):
#   en-US-Neural2-F     — warm female (recommended for positive_thinking)
#   en-US-Neural2-D     — deep male (good for devotional)
#   en-US-Journey-F     — newer Journey voice, extremely natural
#   en-US-Studio-O      — studio-grade female (higher quality tier)
#   en-IN-Neural2-A     — Indian English female
#   en-IN-Neural2-B     — Indian English male
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_LANG=en-US

# --- VOICE OPTION 2 (FALLBACK): ElevenLabs Turbo v2.5 ---
# NOTE: Free tier can no longer use library voices via API (as of late 2025).
# You need Starter tier ($5/mo) for API access to library voices, OR clone your own.
# If both this and Google TTS are set, Google TTS is tried first.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- AI VIDEO (Fal.ai — $10 signup credit, then ~$0.40/clip on Kling 2.0) ---
# Get at: https://fal.ai/dashboard/keys
# Falls through to Wan local → Pexels stock if missing.
FAL_API_KEY=

# Kling 2.0 Master ($0.40/clip) — recommended for ₹1000/month budget.
# Alternatives:
#   fal-ai/ltx-video                          ~$0.02/clip  (low quality)
#   fal-ai/wan-t2v-14b                        ~$0.20/clip  (good, ≈ Kling 1.5)
#   fal-ai/hailuo-02/standard/text-to-video   ~$0.30/clip  (very good)
#   fal-ai/kling-video/v2/master/text-to-video ~$0.40/clip (recommended)
#   fal-ai/veo3-fast                          ~$0.75/clip  (near-SOTA)
#   fal-ai/kling-video/v2-5/pro/text-to-video ~$1.50/clip  (full SOTA)
FAL_MODEL=fal-ai/kling-video/v2/master/text-to-video

# --- STOCK VIDEO (Pexels — free, unlimited) ---
# Get at: https://www.pexels.com/api/
# Without this: pipeline uses gradient placeholders (ugly). Strongly recommended.
PEXELS_API_KEY=

# --- BACKGROUND MUSIC ---
# Primary: seed local library at io_data/bgm/{niche}/*.mp3 (recommended, reliable).
#   See docs/bgm_library_setup.md — 15 min one-time setup, then hands-off.
# Fallback: Pixabay Music API (deprecated but may still work for some accounts).
PIXABAY_API_KEY=

# --- YOUTUBE UPLOAD ---
# These are file paths (not secrets themselves — the actual OAuth JSON files
# live at these paths and are gitignored).
# One-time setup: python scripts/setup_youtube_oauth.py
YOUTUBE_CLIENT_SECRETS_JSON=config/youtube_client_secret.json
YOUTUBE_TOKEN_JSON=config/youtube_token.json

# --- CHANNEL DEFAULTS ---
CHANNEL_NAME=OptimistMantra
DEFAULT_NICHE=positive_thinking
